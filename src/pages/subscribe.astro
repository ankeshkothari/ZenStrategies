---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Subscribe">
  <section class="subscribe">
    <h1>Subscribe to ZenStrategies</h1>
    <p>One email per week. With one or two stories. And an action summary. That will help you live a happy meaningful life.</p>
    <p>Subscribe below to get started.</p>
  </section>
</BaseLayout>

<style>
  .subscribe {
    text-align: center;
    padding: var(--spacing-xl) 0;
  }

  .subscribe h1 {
    margin-bottom: var(--spacing-lg);
  }
</style>
